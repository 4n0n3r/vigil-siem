# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Host and port the API listens on (used by uvicorn and docker-compose)
VIGIL_API_HOST=0.0.0.0
VIGIL_API_PORT=8001

# The URL that the CLI uses to reach this API
# Set this in the CLI environment, not the API environment.
# VIGIL_API_URL=http://localhost:8001
