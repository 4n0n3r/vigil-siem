# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Host and port the API listens on (used by uvicorn and docker-compose)
VIGIL_API_HOST=0.0.0.0
VIGIL_API_PORT=8001

# The URL that the CLI uses to reach this API
# Set this in the CLI environment, not the API environment.
# VIGIL_API_URL=http://localhost:8001

# ClickHouse connection string
# Docker (default, self-hosted, no TLS):
CLICKHOUSE_DSN=clickhouse://default:@clickhouse:8123/default
# ClickHouse Cloud (bring your own, TLS required):
# CLICKHOUSE_DSN=clickhouse://default:password@your-host.clickhouse.cloud:8443/default?secure=true

# PostgreSQL connection string
# Docker (default):
POSTGRES_DSN=postgresql://vigil:vigil@postgres:5432/vigil
# External:
# POSTGRES_DSN=postgresql://vigil:password@localhost:5432/vigil

# Set to true to require X-Vigil-Key on all non-public endpoints.
# Public endpoints (always accessible): GET /v1/status, POST /v1/endpoints/register
VIGIL_REQUIRE_AUTH=false

# Log level for the API: debug | info | warning | error (default: info)
VIGIL_LOG_LEVEL=info
